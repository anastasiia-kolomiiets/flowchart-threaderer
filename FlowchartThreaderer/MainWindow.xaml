<Window x:Class="FlowchartThreaderer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlowchartThreaderer"
        mc:Ignorable="d"
        Title="ThreadFlow Editor" Height="600" Width="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F0F0F0" Padding="10">
            <StackPanel>
                <Button Content="Додати дію" Click="AddAction_Click" Margin="0,5"/>
                <Button Content="Додати умову" Click="AddCondition_Click" Margin="0,5"/>
                <Button Content="Видалити блок" Click="DeleteBlock_Click" Margin="0,5" Background="Crimson"/>
                <Button Content="Зберегти проект у JSON" Click="SaveProject_Click" Margin="0,5"/>
                <Button Content="Завантажити проект з JSON" Click="LoadProject_Click" Margin="0,5"/>
                <Button Content="Генерувати код C#" Click="GenerateCode_Click" Margin="0,5" Background="LightGreen"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Canvas Name="MainCanvas" Background="White" Width="2000" Height="2000" 
                    MouseMove="Canvas_MouseMove" MouseUp="Canvas_MouseUp" MouseDown="MainCanvas_MouseDown"/>
        </ScrollViewer>

        <Border Grid.Column="2" Background="#F9F9F9" Padding="10">
            <StackPanel>
                <TextBlock Text="Команда:"/>
                <TextBox Name="txtCommand" TextChanged="txtCommand_TextChanged" Margin="0,5"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>