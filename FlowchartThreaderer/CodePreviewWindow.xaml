<Window x:Class="FlowchartThreaderer.CodePreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlowchartThreaderer"
        mc:Ignorable="d"
        Title="Згенерований код" Height="450" Width="600" WindowStartupLocation="CenterOwner">
    <Grid>
        <TextBox x:Name="TxtCode" FontFamily="Consolas" FontSize="14" 
                 AcceptsReturn="True" HorizontalScrollBarVisibility="Auto" 
                 VerticalScrollBarVisibility="Auto" IsReadOnly="True" Margin="10"/>
    </Grid>
</Window>
