<UserControl x:Class="FlowchartThreaderer.ConnectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlowchartThreaderer"
             IsHitTestVisible="False">
    <Canvas>
        <Line x:Name="ConnectorLine" Stroke="Black" StrokeThickness="2" />
        <Polygon x:Name="ArrowHead" Fill="Black" Points="0,0 10,5 0,10" />
        <TextBlock x:Name="LabelText" Text="" FontWeight="Bold" Background="White" Padding="2,0"/>
    </Canvas>
</UserControl>
