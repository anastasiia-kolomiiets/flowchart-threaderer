<Window x:Class="FlowchartThreaderer.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlowchartThreaderer"
        mc:Ignorable="d"
        Title="Панель автоматичного тестування" Height="700" Width="1000"
        Background="#F5F5F7" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#F0F0F0" Padding="10">
            <StackPanel>

                <TextBlock Text="Параметри" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Text="Глибина K:"/>
                <Slider x:Name="sldK" Minimum="1" Maximum="20" Value="20" Margin="0,5" TickFrequency="1" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True"/>
                <TextBox x:Name="txtK" Text="{Binding ElementName=sldK, Path=Value}" Margin="0,5"/>

                <Separator Margin="0,10"/>

                <Button Content="Запустити всі" Click="RunAllTests_Click" Margin="0,5"/>
                <Button Content="Запустити поточний" Click="RunCurrentTest_Click" Margin="0,5"/>
                <Button Content="Перервати" Click="CancelButton_Click" Margin="0,5" Background="Crimson" Foreground="White"/>
                <Button Content="Очистити" Click="ClearTests_Click" Margin="0,5"/>

                <Separator Margin="0,10"/>

                <TextBlock Text="Додати тест" FontWeight="Bold" Margin="0,5"/>

                <TextBlock Text="Input:"/>
                <TextBox x:Name="txtInput" Height="50" AcceptsReturn="True" Margin="0,5"/>

                <TextBlock Text="Expected:"/>
                <TextBox x:Name="txtExpected" Height="50" AcceptsReturn="True" Margin="0,5"/>

                <Button Content="Додати тест" Click="AddTest_Click" Margin="0,5" Background="LightGreen"/>

            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="10">
                <StackPanel>
                    <TextBlock Text="Тести" FontWeight="Bold"/>

                    <ListView x:Name="lvTests" SelectionChanged="LvTests_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ID" DisplayMemberBinding="{Binding Id}" Width="40"/>
                                <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="120"/>
                                <GridViewColumn Header="Input" DisplayMemberBinding="{Binding InputPreview}" Width="150"/>
                                <GridViewColumn Header="Expected" DisplayMemberBinding="{Binding ExpectedPreview}" Width="150"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#F9F9F9" Padding="10">
                <StackPanel>

                    <TextBlock Text="Результати" FontWeight="Bold"/>

                    <TextBlock x:Name="txtStatus" Text="Готово" Margin="0,5"/>

                    <ProgressBar x:Name="pbProgress" Height="10" Margin="0,5"/>

                    <TextBlock Text="Покриття:" Margin="0,5"/>
                    <TextBlock x:Name="txtPercentage" Text="0%"/>

                    <TextBlock Text="Унікальні виводи:" Margin="0,10,0,5"/>
                    <ListBox x:Name="lbUniqueOutputs" Height="100"/>

                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>