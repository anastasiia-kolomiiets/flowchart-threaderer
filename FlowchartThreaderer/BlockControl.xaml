<UserControl x:Class="FlowchartThreaderer.BlockControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FlowchartThreaderer"
             mc:Ignorable="d" 
             Width="100" Height="60">
    <Grid>
        <Rectangle x:Name="RectShape" Fill="LightBlue" Stroke="Black" StrokeThickness="2" Visibility="Collapsed"/>

        <Path x:Name="RhombShape" Fill="LightYellow" Stroke="Black" StrokeThickness="2" 
              Stretch="Fill" Data="M 50,0 L 100,30 L 50,60 L 0,30 Z" Visibility="Collapsed"/>

        <TextBlock x:Name="TxtCommand" Text="V1=0" VerticalAlignment="Center" 
                   HorizontalAlignment="Center" TextAlignment="Center" 
                   TextWrapping="Wrap" Margin="5" IsHitTestVisible="False"/>
    </Grid>
</UserControl>